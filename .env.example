# SentinelX GovTrust — Environment Configuration
# Copy this file to .env and fill in your values

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://root:rootpassword@localhost:5432/sentinelx"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="sentinelx-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"

# ─── AI / OpenAI ─────────────────────────────────────────────────────────────
# Leave empty to use local RAG fallback (no OpenAI calls made)
OPENAI_API_KEY="AIzaSyAgvd1LgsbdU4Gx6riy85G09UL_o2Ik_vw"

# ─── Blockchain ──────────────────────────────────────────────────────────────
# Local Hardhat: http://localhost:8545
# Polygon Mumbai: https://rpc-mumbai.maticvigil.com
BLOCKCHAIN_RPC_URL="http://localhost:8545"

# Private key of the deployer wallet (get from `npx hardhat node` output)
BLOCKCHAIN_PRIVATE_KEY=""

# Contract address from deployment (run: cd smart_contracts && npx hardhat run scripts/deploy.js --network localhost)
CONTRACT_ADDRESS=""

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
